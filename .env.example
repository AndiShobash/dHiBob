DATABASE_URL="postgresql://dhibob:dhibob_secret@localhost:5432/dhibob"
TEST_DATABASE_URL="postgresql://dhibob:dhibob_secret@localhost:5432/dhibob_test"
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
REDIS_URL="redis://localhost:6379"

# External notifications (optional — dispatcher silently skips a channel if its vars are missing)
# Resend — https://resend.com (free tier up to 3k emails/month)
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL="DHiBob <notifications@develeap.com>"
# Slack bot — see docs/slack-bot-setup.md for scopes and install steps
SLACK_BOT_TOKEN=
# Base URL used in outgoing notification links (falls back to http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000
