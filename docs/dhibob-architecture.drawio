        <mxCell id="approver" value="Time-Off Approval Chain:&#xa;HR + Team Leader + Group Leader&#xa;All 3 must approve → APPROVED&#xa;Any 1 rejects → REJECTED" style="text;html=1;fontSize=9;align=left;verticalAlign=top;fillColor=#f9fafb;strokeColor=#e5e7eb;rounded=1;spacingLeft=8;spacingTop=5;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="560" y="210" width="220" height="75" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
